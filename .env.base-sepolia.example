# The Base Sepolia deployment - copy to .env.local and fill in the indexer endpoint
# (README, "Base Sepolia"). Deployment pipeline: contracts -> indexer -> frontend.
VITE_ARBORVOTE_ADDRESS=0xF7421e860a9559a609963AbC4900394134e7AaCf
VITE_RPC_URL=https://sepolia.base.org
# The hosted indexer's GraphQL endpoint, shown in the envio.dev app after it deploys.
VITE_INDEXER_URL=<https://indexer.dev.hyperindex.xyz/…/v1/graphql>
# Reads are digest-verified, so an untrusted public gateway is fine.
VITE_IPFS_GATEWAY=https://ipfs.io
# Leave unset until a hosted, origin-restricted kubo API exists: without it, authored
# texts are committed digest-only and other clients cannot resolve them (README,
# "Argument content and IPFS").
# VITE_IPFS_API=
